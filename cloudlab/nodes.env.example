# Copy to cloudlab/nodes.env and fill in after reserving the 4 experiments.
# These are the PUBLIC control-network hostnames CloudLab shows on each
# experiment's "List View" (the ssh target), one per cluster.
#
#   role      cluster      paxosbus index / job
#   --------  -----------  --------------------------------
#   client    Utah         clients (NUM_CLIENTS of them)
#   replica0  Wisconsin    replica -i 0   (initial leader)
#   replica1  Clemson      replica -i 1
#   replica2  Mass         replica -i 2

SSH_USER=austintan

CLIENT_HOST=                      # Utah     e.g. amd042.utah.cloudlab.us
REPLICA0_HOST=                    # Wisconsin (leader) e.g. c220g5-110530.wisc.cloudlab.us
REPLICA1_HOST=                    # Clemson  e.g. clnode204.clemson.cloudlab.us
REPLICA2_HOST=                    # Mass     e.g. ms0610.mass.cloudlab.us

# Human-readable per-node latency labels (shown in every log line). Edit if you
# change the cluster->role mapping above.
CLIENT_LABEL=utah
REPLICA0_LABEL=wisc
REPLICA1_LABEL=clemson
REPLICA2_LABEL=mass
